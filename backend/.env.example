# MongoDB Connection
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/veritas_db?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=supersecretjwtsecretchangeinproduction1234567890!@#$
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Gemini API Key
GEMINI_API_KEY=AIzaSyYourGeminiApiKeyHere

# Brave Search API Key
BRAVE_API_KEY=bsYourBraveApiKeyHere

# Tavily Search API Key
TAVILY_API_KEY=tvly-YourTavilyApiKeyHere

# CORS Settings
# Comma-separated list of allowed origins. E.g., http://localhost:5173,https://veritas-ai.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# Cookie Settings
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Server Settings
PORT=8000
ENVIRONMENT=development
